# Viam provisioning key — an API key authorized to create machines and
# retrieve cloud credentials. Used by provision-batch.sh only.
# Never deployed to target machines.
#
# Create one at app.viam.com > Organization Settings > API Keys,
# scoped to the org or location where machines will be provisioned.
VIAM_API_KEY_ID=your-api-key-id-here
VIAM_API_KEY=your-api-key-here
VIAM_ORG_ID=your-org-id-here
VIAM_LOCATION_ID=your-location-id-here
