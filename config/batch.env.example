# Batch provisioning config — copy to e.g. config/meerkat.env and fill in.
# Usage: ./scripts/provision-batch.sh --config config/meerkat.env

COUNT=6
PREFIX=lab-meerkat

# Viam provisioning key
VIAM_API_KEY_ID=your-api-key-id-here
VIAM_API_KEY=your-api-key-here
VIAM_ORG_ID=your-org-id-here
VIAM_LOCATION_ID=your-location-id-here
